#!/usr/bin/env python3
"""Generate hyprsunset.conf with sunrise/sunset times for a given location,
then exec hyprsunset. Uses only the Python standard library (solar position
algorithm accurate to ~1 minute)."""

import argparse
import json
import math
import datetime
import os
import urllib.request

# Fallback: Montreal
DEFAULT_LATITUDE = 45.5017
DEFAULT_LONGITUDE = -73.5673

CONFIG_PATH = os.path.expanduser("~/.config/hypr/hyprsunset.conf")


def solar_noon_and_offset(date, latitude, longitude):
    """Return sunrise/sunset as UTC minutes from midnight using the NOAA
    solar position algorithm."""
    # Day of year
    n = date.timetuple().tm_yday

    # Fractional year in radians
    gamma = 2 * math.pi / 365 * (n - 1)

    # Equation of time (minutes)
    eqtime = 229.18 * (
        0.000075
        + 0.001868 * math.cos(gamma)
        - 0.032077 * math.sin(gamma)
        - 0.014615 * math.cos(2 * gamma)
        - 0.040849 * math.sin(2 * gamma)
    )

    # Solar declination (radians)
    decl = (
        0.006918
        - 0.399912 * math.cos(gamma)
        + 0.070257 * math.sin(gamma)
        - 0.006758 * math.cos(2 * gamma)
        + 0.000907 * math.sin(2 * gamma)
        - 0.002697 * math.cos(3 * gamma)
        + 0.00148 * math.sin(3 * gamma)
    )

    lat_rad = math.radians(latitude)

    # Hour angle for sunrise/sunset (degrees)
    cos_ha = (
        math.cos(math.radians(90.833)) / (math.cos(lat_rad) * math.cos(decl))
        - math.tan(lat_rad) * math.tan(decl)
    )

    # Clamp for polar day/night
    cos_ha = max(-1, min(1, cos_ha))
    ha = math.degrees(math.acos(cos_ha))

    # Solar noon in minutes from midnight UTC
    noon_minutes = 720 - 4 * longitude - eqtime

    sunrise_minutes = noon_minutes - ha * 4
    sunset_minutes = noon_minutes + ha * 4

    return sunrise_minutes, sunset_minutes


def minutes_to_local_hhmm(utc_minutes, tz_offset_hours):
    """Convert UTC minutes-from-midnight to local HH:MM string."""
    local = utc_minutes + tz_offset_hours * 60
    local = local % 1440
    h = int(local // 60)
    m = int(local % 60)
    return f"{h:02d}:{m:02d}"


def get_location():
    """Get latitude/longitude via IP geolocation, fall back to defaults."""
    try:
        req = urllib.request.Request(
            "http://ip-api.com/json/?fields=lat,lon,city",
            headers={"User-Agent": "hyprsunset-location"},
        )
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read())
            return data["lat"], data["lon"], data.get("city", "Unknown")
    except Exception:
        return DEFAULT_LATITUDE, DEFAULT_LONGITUDE, "Montreal (fallback)"


def get_tz_offset():
    """Get the current UTC offset in hours from the system timezone."""
    now = datetime.datetime.now(datetime.timezone.utc)
    local_now = now.astimezone()
    return local_now.utcoffset().total_seconds() / 3600


def main():
    parser = argparse.ArgumentParser(description="Generate hyprsunset.conf with location-based sunrise/sunset times")
    parser.add_argument("--night-temperature", type=int, default=4000, help="Color temperature in Kelvin after sunset (default: 4000)")
    args = parser.parse_args()

    latitude, longitude, city = get_location()
    tz_offset = get_tz_offset()
    today = datetime.date.today()

    sunrise_utc, sunset_utc = solar_noon_and_offset(today, latitude, longitude)

    sunrise = minutes_to_local_hhmm(sunrise_utc, tz_offset)
    sunset = minutes_to_local_hhmm(sunset_utc, tz_offset)

    print(f"Location: {city} ({latitude:.4f}°N, {longitude:.4f}°E)")
    print(f"Date: {today} (UTC offset: {tz_offset:+.0f}h)")
    print(f"Sunrise: {sunrise}, Sunset: {sunset}")
    print(f"Writing {CONFIG_PATH}")

    config = f"""\
# Auto-generated by hyprsunset-location
# {today} — Sunrise: {sunrise}, Sunset: {sunset}

profile {{
    time = {sunrise}
    temperature = 6500
}}

profile {{
    time = {sunset}
    temperature = {args.night_temperature}
}}
"""

    os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
    with open(CONFIG_PATH, "w") as f:
        f.write(config)

    # Exec hyprsunset (replaces this process)
    os.execvp("hyprsunset", ["hyprsunset"])


if __name__ == "__main__":
    main()
