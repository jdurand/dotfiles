#
# Theme
#
theme = TokyoNight Storm

#
# Font
#
font-family = VictorMono Nerd Font Mono
font-size = 15
font-thicken = true
font-feature = +ss05, +ss06 # alternatives for 0 and 7
# font-feature = -calt, -liga, -dlig # disable ligatures
# font-family-italic = VictorMono Nerd Font Mono Oblique

#
# Appearance
#
# Hide window decorations, suitable for tiling window managers
# macos-non-native-fullscreen = true
macos-titlebar-style = hidden

# macos-icon = holographic
# Alternatives: official, blueprint, chalkboard, microchip, glass, holographic, paper, retro, xray, custom, custom-style
bold-is-bright = true
cursor-color = #5ebfcf
background-opacity = 0.85
background-blur = 10
window-padding-balance = true
window-padding-x = 7
window-padding-y = 7

#
# Clipboard settings
#
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true
# clipboard-paste-protection = false

#
# Window behaviour
#
# Confirm before closing
confirm-close-surface = false

# This setting hides the mouse cursor while typing to reduce distractions.
mouse-hide-while-typing = true

# Have Ghostty quit when all the top-level windows are closed
quit-after-last-window-closed = true

# Use the Display P3 color space for color interpretation
window-colorspace = display-p3

#
# Keybinds
#
# Disable new tab creation
keybind = super+t=ignore

# Reload config
keybind = cmd+shift+r=reload_config

# Set Alt+... keybindings for correct escape sequences
keybind = alt+h=text:\x1bh
keybind = alt+j=text:\x1bj
keybind = alt+k=text:\x1bk
keybind = alt+l=text:\x1bl
keybind = alt+v=text:\x1bv

# Toggle fullscreen
keybind = f11=toggle_fullscreen

# Shift + Enter = line jump
keybind = shift+enter=text:\n

# This workaround remaps Ctrl+i to Ctrl+a in Tmux to prevent it from being
# interpreted as TAB, enabling proper handling in child programs, like Neovim.
keybind = ctrl+i=text:\x1bi

# Split keybinds for Supacode, which embeds Ghostty and reads this same config.
# ctrl+hjkl = navigate/focus a split, ctrl+shift+hjkl = create a split; h/j/k/l =
# left/down/up/right. The nav binds use the `performable:` prefix: Ghostty only
# consumes the key when the action actually moves focus (i.e. a split exists in
# that direction); otherwise it falls through to the program. So in the
# standalone tmux setup — almost always a single Ghostty pane — ctrl+hjkl still
# reaches tmux/nvim for their own pane/split navigation, while in Supacode's
# real splits it navigates panes.
keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right
keybind = ctrl+shift+h=new_split:left
keybind = ctrl+shift+j=new_split:down
keybind = ctrl+shift+k=new_split:up
keybind = ctrl+shift+l=new_split:right

# ctrl+alt+hjkl resize the focused split (left/down/up/right, by 10px).
keybind = ctrl+alt+h=resize_split:left,25
keybind = ctrl+alt+j=resize_split:down,25
keybind = ctrl+alt+k=resize_split:up,25
keybind = ctrl+alt+l=resize_split:right,25

# Tab management in Supacode (tabs ≈ tmux windows). ctrl+shift+n opens a new
# tab; ctrl+shift+u / ctrl+shift+i cycle to the previous / next tab.
keybind = ctrl+shift+n=new_tab
keybind = ctrl+shift+u=previous_tab
keybind = ctrl+shift+i=next_tab

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
