{
  "description": "Apple Mail Vim-like Navigation (Ctrl+J/K/E)",
  "manipulators": [
    {
      "type": "basic",
      "from": {
        "key_code": "j",
        "modifiers": { "mandatory": ["control"] }
      },
      "to": [{ "key_code": "down_arrow" }],
      "conditions": [
        {
          "type": "frontmost_application_if",
          "bundle_identifiers": ["^com\\.apple\\.mail$"]
        }
      ]
    },
    {
      "type": "basic",
      "from": {
        "key_code": "k",
        "modifiers": { "mandatory": ["control"] }
      },
      "to": [{ "key_code": "up_arrow" }],
      "conditions": [
        {
          "type": "frontmost_application_if",
          "bundle_identifiers": ["^com\\.apple\\.mail$"]
        }
      ]
    },
    {
      "type": "basic",
      "from": {
        "key_code": "e",
        "modifiers": { "mandatory": ["control"] }
      },
      "to": [{
        "key_code": "a",
        "modifiers": ["control", "command"]
      }],
      "conditions": [
        {
          "type": "frontmost_application_if",
          "bundle_identifiers": ["^com\\.apple\\.mail$"]
        }
      ]
    }
  ]
}
