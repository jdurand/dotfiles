{
  "reload_style_on_change": true,
  "layer": "top",
  "position": "top",
  "width": 1700,
  "margin-top": 6,
  "margin-right": 10,
  "margin-bottom": -3,
  "margin-left": 10,
  "spacing": 0,

  "modules-left": [
    "hyprland/workspaces#rw"
  ],
  "modules-center": [
    "custom/omarchy",
    "clock#5",
    "custom/weather",
    "custom/update",
    "custom/voxtype",
    "custom/screenrecording-indicator",
    "custom/idle-indicator",
    "custom/notification-silencing-indicator",
    "mpris"
  ],
  "modules-right": [
    "group/notify",
    "group/tray-expander",
    "hyprland/language",
    "custom/separator#blank_2",
    "disk",
    "memory",
    "cpu",
    "custom/separator#blank_2",
    "network",
    "bluetooth",
    "pulseaudio",
    "battery",
    "custom/separator#blank_2",
    "custom/power",
    "custom/separator#blank_2"
  ],

  // Workspaces with window-rewrite app icons
  "hyprland/workspaces#rw": {
    "disable-scroll": true,
    "all-outputs": true,
    "warp-on-scroll": false,
    "sort-by-number": true,
    "show-special": false,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    },
    "format": "{icon} {windows}",
    "format-window-separator": " ",
    "window-rewrite-default": "¾░ÇÅ ",
    "window-rewrite": {
      "title<.*amazon.*>": "¾░àÂ ",
      "title<.*reddit.*>": "¾░æì ",
      "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "¾░ê╣ ",
      "class<zen>": "¾░░À ",
      "class<waterfox|waterfox-bin>": "¾░ê╣ ",
      "class<microsoft-edge>": "¾░ç® ",
      "class<Chromium|Thorium|[Cc]hrome>": "¾░è» ",
      "class<brave-browser>": "¾░è» ",
      "class<tor browser>": "¾░è» ",
      "class<kitty|konsole>": "¾░åì ",
      "class<kitty-dropterm>": "¾░åì ",
      "class<com.mitchellh.ghostty>": "¾░èá ",
      "class<org.wezfurlong.wezterm>": "¾░åì ",
      "class<Alacritty>": "¾░åì ",
      "class<[Tt]hunderbird|[Tt]hunderbird-esr>": "¾░ç« ",
      "title<.*gmail.*>": "¾░è½ ",
      "class<[Tt]elegram-desktop|org.telegram.desktop>": "´çÖ ",
      "class<discord|[Ww]ebcord|Vesktop>": "¾░Ö» ",
      "class<slack>": "¾░Æ▒ ",
      "title<.*whatsapp.*>": "¾░ûú ",
      "title<.*ChatGPT.*>": "¾░Ü® ",
      "class<mpv>": "¾░Éî ",
      "class<celluloid|Zoom>": "¾░Éî ",
      "class<vlc>": "¾░ò╝ ",
      "class<[Ss]potify>": "¾░ôç ",
      "class<VSCode|code-url-handler|code-oss|codium|VSCodium>": "¾░¿× ",
      "class<dev.zed.Zed>": "¾░Áü ",
      "class<jetbrains-idea>": "¾░¼À ",
      "class<obs|com.obsproject.Studio>": "¾░æï ",
      "class<steam>": "¾░ôô ",
      "class<thunar|nemo|nautilus>": "¾░Ø░ ",
      "class<gimp>": "¾░âú ",
      "class<virt-manager>": "¾░û│ ",
      "title<.*nvim.*>": "¾░òÀ ",
      "title<.*vim.*>": "¾░òÀ ",
      "title<.*figma.*>": "¾░ê½ ",
      "title<.*jira.*>": "¾░îâ ",
      "title<.*youtube.*>": "¾░ùâ ",
      "title<.*Picture-in-Picture.*>": "¾░Éî "
    }
  },

  "custom/omarchy": {
    "format": "¾░ì£",
    "on-click": "omarchy-menu",
    "on-click-right": "xdg-terminal-exec",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },

  "clock#5": {
    "format": "{:%a %d | %H:%M}",
    "format-alt": "{:%A, %d %B, %Y (%R)}",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "custom/weather": {
    "format": "{}",
    "format-alt": "{alt}: {}",
    "format-alt-click": "click",
    "interval": 1800,
    "return-type": "json",
    "exec": "$HOME/.config/waybar/scripts/weather.sh",
    "tooltip": true
  },

  "custom/update": {
    "format": "",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 21600
  },

  "custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "¾░ì¼",
      "transcribing": "¾░öƒ"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },

  "custom/screenrecording-indicator": {
    "on-click": "omarchy-cmd-screenrecord",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/screen-recording.sh",
    "signal": 8,
    "return-type": "json"
  },

  "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },

  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "signal": 10,
    "return-type": "json"
  },

  "mpris": {
    "interval": 1,
    "format": "{player_icon} {status_icon} <i>{dynamic}</i>",
    "on-click-middle": "playerctl previous",
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "scroll-step": 5.0,
    "smooth-scrolling-threshold": 1,
    "tooltip": true,
    "tooltip-format": "{dynamic}\nLeft: Play/Pause | Middle: Previous | Right: Next",
    "player-icons": {
      "chromium": "",
      "default": "",
      "firefox": "",
      "mpv": "¾░É╣",
      "spotify": "",
      "vlc": "¾░ò╝"
    },
    "status-icons": {
      "paused": "¾░ÉÄ",
      "playing": "",
      "stopped": ""
    },
    "max-length": 30
  },

  "group/notify": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "custom/notifications",
      "transition-left-to-right": false
    },
    "modules": ["custom/notifications", "custom/dot_update"]
  },

  "custom/notifications": {
    "tooltip": true,
    "tooltip-format": "Left Click: Show Last Notification\nRight Click: Clear All",
    "format": " ",
    "on-click": "makoctl invoke",
    "on-click-right": "makoctl dismiss --all",
    "escape": true
  },

  "custom/dot_update": {
    "format": " {}",
    "exec": "checkupdates | wc -l",
    "exec-if": "[[ $(checkupdates | wc -l) ]]",
    "interval": 43200,
    "tooltip": true,
    "tooltip-format": "System updates available"
  },

  "network": {
    "format-icons": ["¾░ñ»", "¾░ñƒ", "¾░ñó", "¾░ñÑ", "¾░ñ¿"],
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-ethernet": "¾░îÿ",
    "format-disconnected": "¾░îÖ",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%\nÔçú{bandwidthDownBytes}  Ôçí{bandwidthUpBytes}",
    "tooltip-format-ethernet": "{ifname} ¾░îÿ\nÔçú{bandwidthDownBytes}  Ôçí{bandwidthUpBytes}",
    "tooltip-format-disconnected": "¾░îÖ Disconnected",
    "max-length": 30,
    "on-click": "omarchy-launch-wifi"
  },

  "bluetooth": {
    "format": " ",
    "format-disabled": "¾░é│",
    "format-connected": "¾░é▒ {num_connections}",
    "format-no-controller": "¾░é▓",
    "tooltip-format": " {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": " {device_alias} ¾░éä{device_battery_percentage}%",
    "tooltip": true,
    "on-click": "omarchy-launch-bluetooth"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-muted": "¾░Øƒ 0%",
    "format-icons": {
      "headphone": "¾░ïï",
      "headset": "¾░ïÄ",
      "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"]
    },
    "scroll-step": 5.0,
    "on-click": "omarchy-launch-audio",
    "on-click-right": "pamixer -t",
    "tooltip-format": "{desc} | {volume}%",
    "smooth-scrolling-threshold": 1
  },

  "cpu": {
    "format": "{usage}% ¾░ìø",
    "interval": 5,
    "min-length": 5,
    "on-click": "omarchy-launch-or-focus-tui btop"
  },

  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{icon}",
    "format-charging": "{icon}",
    "format-plugged": "",
    "format-icons": {
      "charging": ["¾░ó£", "¾░éå", "¾░éç", "¾░éê", "¾░óØ", "¾░éë", "¾░ó×", "¾░éè", "¾░éï", "¾░éà"],
      "default": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"]
    },
    "format-full": "¾░éà",
    "tooltip-format-discharging": "{power:>1.0f}WÔåô {capacity}%",
    "tooltip-format-charging": "{power:>1.0f}WÔåæ {capacity}%",
    "interval": 5,
    "on-click": "omarchy-menu power",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },

  "hyprland/language": {
    "format": "¾░îî {}",
    "format-en": "EN",
    "format-fr": "FR",
    "format-es": "ES",
    "format-de": "DE",
    "on-click": "hyprctl switchxkblayout all next"
  },

  "memory": {
    "interval": 10,
    "format": "{used:0.1f}G ¾░¥å",
    "format-alt": "{percentage}% ¾░¥å",
    "format-alt-click": "click",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB",
    "on-click-right": "omarchy-launch-or-focus-tui btop"
  },

  "disk": {
    "interval": 30,
    "path": "/",
    "format": "{percentage_used}% ¾░ïè",
    "tooltip-format": "{used} used of {total} on {path} ({percentage_used}%)"
  },

  "custom/power": {
    "format": "ÔÅ╗",
    "on-click": "omarchy-menu system",
    "tooltip": true,
    "tooltip-format": "Lock / Logout / Restart / Shutdown"
  },

  "custom/separator#blank_2": {
    "format": "  ",
    "interval": "once",
    "tooltip": false
  },

  "group/tray-expander": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 600,
      "children-class": "tray-group-item"
    },
    "modules": ["custom/expand-icon", "tray"]
  },

  "custom/expand-icon": {
    "format": "¾░àü",
    "tooltip": false
  },

  "tray": {
    "icon-size": 16,
    "spacing": 4
  }
}
